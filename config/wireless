config wifi-iface
    option device 'radio0'
    option network 'lan'
    option mode 'ap'
    option ssid 'YourSSID'
    option encryption 'psk2'
    option key 'YourPassword'
    option wmm '1'
    option ieee80211r '1'
    option mobility_domain '4f56'
    option reassoc_retries '3'
    option ft_over_ds '1'
    option ft_psk_generate_local '1'
    option pmf '1'